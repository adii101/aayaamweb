# MongoDB - used for OTP (phone login), users, events, registrations
MONGODB_URI=mongodb://localhost:27017/

# Admin: phone number allowed to log in as admin via OTP (e.g. 70007799744 for Adi)
ADMIN_PHONE=70007799744
# Admin password (for password-based admin login)
ADMIN_PASSWORD=admin

# Session secret for admin login cookie (change in production)
SESSION_SECRET=your-secret-key-change-in-production

# Optional: OTP pepper for phone login
# OTP_SECRET=
